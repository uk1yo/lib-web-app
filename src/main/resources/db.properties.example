# ============================================================
# db.properties.example — шаблон настроек БД
# Скопируйте этот файл в db.properties и укажите свои данные.
# НИКОГДА не коммитьте db.properties с реальными паролями!
# ============================================================

db.url=jdbc:postgresql://localhost:5432/library_db
db.username=YOUR_DB_USER
db.password=YOUR_DB_PASSWORD
db.driver=org.postgresql.Driver

db.pool.size=10
db.pool.timeout.ms=5000
